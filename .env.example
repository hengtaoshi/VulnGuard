# DeepSeek API 配置（AI 扫描和分析功能需要）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# PostgreSQL 数据库配置（扫描记录持久化需要）
DATABASE_URL=postgresql://vulnguard:vulnguard@localhost:5432/vulnguard

# OWASP Dependency-Check NVD API Key（可选，用于加速 NVD 数据库同步）
# 申请地址: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# HTTP/HTTPS 代理配置（可选，用于需要代理的网络环境）
# 格式: http://host:port
HTTP_PROXY=
HTTPS_PROXY=
