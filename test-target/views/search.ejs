<%- include('_header', { title: '搜索', path: '/search' }) %>

<section class="container search-results">
  <h1 class="section-title">站内搜索</h1>

  <form class="filter-bar" action="/search" method="GET">
    <input type="text" name="q" placeholder="输入搜索关键词…" value="<%= typeof q !== 'undefined' ? q : '' %>">
    <button type="submit">搜索</button>
  </form>

  <% if (typeof q !== 'undefined' && q) { %>
    <div class="search-stats">
      搜索 "<%= q %>" — 找到约 <%= results ? results.length : 0 %> 条结果
    </div>

    <!-- VULN: Reflected XSS — q rendered as raw HTML -->
    <div style="background:#111b2e;border:1px solid rgba(79,195,247,.1);border-radius:8px;padding:12px 16px;margin-bottom:20px;font-size:13px;color:#8899b8;">
      您搜索的是: <span style="color:#fff;"><%- q %></span>
    </div>

    <% if (results && results.length > 0) { %>
      <% results.forEach(function(r) { %>
        <div class="blog-card">
          <h2><a href="<%= r.link %>"><%= r.title %></a></h2>
          <p class="excerpt"><%= r.excerpt %></p>
          <div class="meta"><%= r.date %></div>
        </div>
      <% }) %>
    <% } else { %>
      <div style="text-align:center;padding:40px 0;color:#667899;">
        <p>未找到与 "<%= q %>" 相关的结果</p>
      </div>
    <% } %>
  <% } else { %>
    <div style="text-align:center;padding:40px 0;color:#667899;">
      <p style="font-size:18px;">输入关键词搜索站内文章</p>
      <p style="font-size:14px;margin-top:8px;">支持全文搜索，试试"安全"、"漏洞"、"WAF"等关键词</p>
    </div>
  <% } %>
</section>

<%- include('_footer') %>
