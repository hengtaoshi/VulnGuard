<%- include('_header', { title: '错误', path: '' }) %>

<section class="container" style="padding:80px 0;text-align:center;">
  <div style="font-size:64px;margin-bottom:16px;">⚠️</div>
  <h1 style="font-size:28px;color:#fff;margin-bottom:12px;">出现错误</h1>
  <p style="color:#8899b8;font-size:16px;margin-bottom:8px;"><%= typeof message !== 'undefined' ? message : '发生了未知错误' %></p>
  <% if (typeof stack !== 'undefined' && stack) { %>
    <pre style="background:#111b2e;border:1px solid rgba(244,67,54,.3);border-radius:6px;padding:16px;margin-top:20px;text-align:left;font-size:12px;color:#e57373;max-width:700px;margin-left:auto;margin-right:auto;overflow-x:auto;"><%= stack %></pre>
  <% } %>
  <a href="/" style="display:inline-block;margin-top:24px;color:#4fc3f7;">← 返回首页</a>
</section>

<%- include('_footer') %>
