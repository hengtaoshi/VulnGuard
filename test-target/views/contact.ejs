<%- include('_header', { title: '联系我们', path: '/contact' }) %>

<section class="container" style="padding:40px 0;">
  <h1 class="section-title" style="text-align:center;">联系我们</h1>
  <p style="text-align:center;color:#8899b8;margin-bottom:32px;">如有安全评估需求或合作意向，请填写以下表单，我们会尽快回复</p>

  <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert-box alert-success" style="max-width:500px;margin:0 auto 20px;">消息已发送！我们会尽快与您联系。</div>
  <% } %>
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert-box alert-error" style="max-width:500px;margin:0 auto 20px;"><%= error %></div>
  <% } %>

  <div class="form-card">
    <form action="/contact" method="POST">
      <label for="name">姓名</label>
      <input type="text" id="name" name="name" placeholder="请输入姓名" required>

      <label for="email">邮箱</label>
      <input type="email" id="email" name="email" placeholder="your@email.com" required>

      <label for="company">公司</label>
      <input type="text" id="company" name="company" placeholder="公司名称（选填）">

      <label for="subject">主题</label>
      <select id="subject" name="subject" required>
        <option value="">请选择主题</option>
        <option value="penetration-test">渗透测试</option>
        <option value="code-audit">代码审计</option>
        <option value="training">安全培训</option>
        <option value="cooperation">商务合作</option>
        <option value="other">其他</option>
      </select>

      <label for="message">详细描述</label>
      <textarea id="message" name="message" rows="6" placeholder="请描述您的需求…" required></textarea>

      <!-- Hidden field with API endpoint info -->
      <input type="hidden" name="api_endpoint" value="/api/contact-submit">

      <button type="submit">发送消息</button>
    </form>
  </div>

  <div style="text-align:center;margin-top:32px;color:#667899;font-size:14px;">
    <p>📧 security@techinsight-labs.com</p>
    <p>📱 微信: TechInsight_Sec</p>
  </div>
</section>

<%- include('_footer') %>
