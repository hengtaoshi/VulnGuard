<%- include('_header', { title: '首页', path: '/' }) %>

<section class="hero">
  <div class="container">
    <h1>守护数字世界的<span>安全边界</span></h1>
    <p>TechInsight 安全实验室专注于漏洞研究、渗透测试与安全评估，为企业提供全方位的网络安全解决方案。</p>
    <a href="/blog" class="cta">浏览安全研究</a>
  </div>
</section>

<section class="container">
  <div class="features">
    <div class="feature-card">
      <div class="icon">🛡️</div>
      <h3>漏洞挖掘</h3>
      <p>团队成员拥有多年漏洞挖掘经验，发现过数十个高危漏洞并获得 CVE 编号认可。</p>
    </div>
    <div class="feature-card">
      <div class="icon">🔍</div>
      <h3>渗透测试</h3>
      <p>提供全面的黑盒与白盒渗透测试服务，覆盖 Web、移动端、云基础设施等多个领域。</p>
    </div>
    <div class="feature-card">
      <div class="icon">📊</div>
      <h3>安全评估</h3>
      <p>基于行业标准的安全评估体系，为企业提供详细的风险报告与修复建议。</p>
    </div>
    <div class="feature-card">
      <div class="icon">📝</div>
      <h3>安全培训</h3>
      <p>定期举办安全培训课程，帮助企业团队建立安全意识，提升安全开发能力。</p>
    </div>
    <div class="feature-card">
      <div class="icon">🔐</div>
      <h3>代码审计</h3>
      <p>深入的源代码安全审计，发现业务逻辑漏洞与隐蔽后门，确保代码供应链安全。</p>
    </div>
    <div class="feature-card">
      <div class="icon">🌐</div>
      <h3>威胁情报</h3>
      <p>实时威胁情报跟踪，提供最新的攻击手法分析与防御建议，保持安全态势感知。</p>
    </div>
  </div>
</section>

<section class="container">
  <h2 class="section-title">最新安全研究 <small>来自我们的安全研究团队的最新发现</small></h2>
  <% 
    const articles = [
      { id: 1, title: 'OWASP Top 10 2024 — 最新 Web 安全威胁分析', category: 'web安全', excerpt: 'OWASP 发布了最新的 Top 10 安全风险列表，本文详细解读每个风险类别的变化与应对策略。', date: '2024-12-15', author: '安全研究团队' },
      { id: 2, title: '从零开始构建 WAF 绕过测试环境', category: '渗透测试', excerpt: '详细的 WAF 绕过技术综述，包括 SQL 注入绕过、XSS 过滤器绕过等实用技术。', date: '2024-12-10', author: 'PenTest Lab' },
      { id: 3, title: '供应链攻击 — 现代软件开发的最大威胁', category: '安全态势', excerpt: '近年来供应链攻击事件频发，从 SolarWinds 到 Log4j，我们该如何应对？', date: '2024-12-05', author: '威胁分析组' },
    ];
    articles.forEach(a => { 
  %>
  <div class="blog-card">
    <span class="category"><%= a.category %></span>
    <h2><a href="/blog/<%= a.id %>"><%= a.title %></a></h2>
    <div class="meta"><%= a.date %> · 作者: <%= a.author %></div>
    <p class="excerpt"><%= a.excerpt %></p>
  </div>
  <% }) %>
</section>

<%- include('_footer') %>
