<%- include('_header', { title: '个人中心', path: '/user' }) %>

<section class="container" style="padding:40px 0;">
  <h1 class="section-title" style="text-align:center;">个人中心</h1>

  <% if (user) { %>
    <div class="profile-card">
      <div class="avatar-big">👤</div>
      <h2><%= user.username %></h2>
      <div class="email"><%= user.email %></div>

      <!-- IDOR vulnerability: user role exposed, admin can access /user/admin-panel -->
      <div class="field">
        <span class="field-label">角色:</span>
        <span class="field-value"><%= user.role %></span>
      </div>
      <div class="field">
        <span class="field-label">用户ID:</span>
        <span class="field-value"><%= user.id %></span>
      </div>
      <div class="field">
        <span class="field-label">注册时间:</span>
        <span class="field-value"><%= user.joinDate %></span>
      </div>
      <div class="field">
        <span class="field-label">积分:</span>
        <span class="field-value"><%= user.points || 0 %></span>
      </div>

      <div class="bio">
        <%= user.bio || '这个用户很懒，什么都没写…' %>
      </div>
    </div>

    <!-- Admin link (only shows for admin users, but can be forced via IDOR) -->
    <% if (user.role === 'admin') { %>
      <div style="text-align:center;margin-top:20px;">
        <a href="/user/admin-panel" style="color:#e57373;">⚙️ 管理后台</a>
      </div>
    <% } %>

  <% } else { %>
    <div style="text-align:center;padding:40px 0;">
      <p style="font-size:18px;color:#667899;">用户不存在</p>
      <p style="font-size:14px;color:#445;margin-top:8px;">请检查用户ID是否正确</p>
    </div>
  <% } %>

  <!-- Insecure: exposes all user IDs via HTML comment -->
  <!-- Active users: 1=admin, 2=guest, 3=testuser -->
</section>

<%- include('_footer') %>
