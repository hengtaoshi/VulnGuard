<%- include('_header', { title: '网络诊断工具', path: '/tools/ping' }) %>

<section class="container tool-page">
  <h1 class="section-title">网络诊断工具箱</h1>

  <!-- Ping Tool — Command Injection vector -->
  <div class="tool-card">
    <h2>🌐 Ping 诊断</h2>
    <p>测试目标主机的网络连通性。输入 IP 地址或域名进行 ping 测试。</p>
    <form class="tool-input-group" action="/tools/ping" method="GET">
      <input type="text" name="host" placeholder="例如: 8.8.8.8 或 google.com" value="<%= typeof host !== 'undefined' ? host : '' %>">
      <button type="submit">Ping</button>
    </form>
    <% if (typeof output !== 'undefined') { %>
      <div class="tool-output"><%= output %></div>
    <% } %>
  </div>

  <!-- DNS Lookup — Another command injection vector -->
  <div class="tool-card">
    <h2>🔎 DNS 查询</h2>
    <p>查询域名的 DNS 解析记录。</p>
    <form class="tool-input-group" action="/tools/dns" method="GET">
      <input type="text" name="domain" placeholder="例如: example.com" value="<%= typeof domain !== 'undefined' ? domain : '' %>">
      <button type="submit">查询</button>
    </form>
    <% if (typeof dnsOutput !== 'undefined') { %>
      <div class="tool-output"><%= dnsOutput %></div>
    <% } %>
  </div>

  <!-- Server Status (information disclosure) -->
  <div class="tool-card" style="border-color:rgba(244,67,54,.2);">
    <h2>⚠️ 服务器状态</h2>
    <p style="font-size:13px;">
      Node.js <%= typeof nodeVersion !== 'undefined' ? nodeVersion : '' %> | 
      运行时间: <%= typeof uptime !== 'undefined' ? uptime : '' %>
    </p>
    <pre style="font-size:12px;color:#667899;margin-top:8px;"><%= typeof envInfo !== 'undefined' ? envInfo : '' %></pre>
  </div>
</section>

<%- include('_footer') %>
